# Copy this file to imports/transforms/.env and update values for your local database.

# Example: ODBC Driver 18 for SQL Server
DB_DRIVER=ODBC Driver 18 for SQL Server

# Example: localhost, localhost\SQLEXPRESS, or a SQL Server host name
DB_SERVER=localhost

# Local/development ASA database name
DB_DATABASE=MySBU_ASA

# Supported values: windows or sql
DB_AUTH=windows

# Only required when DB_AUTH=sql
DB_USERNAME=
DB_PASSWORD=
